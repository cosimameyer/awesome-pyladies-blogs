{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "name":            {"type": "string"},
    "title":           {"type": "string"},
    "description":     {"type": "string"},
    "logo_url":        {"type": ["string", "null"]},
    "repo_url":        {"type": "string"},
    "bug_reports_url": {"type": "string"},
    "pypi_url":        {"type": "string"},
    "docs_url":        {"type": ["string", "null"]},
    "last_updated":    {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "social_media": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "twitter":      {"type": "string"},
                "mastodon":     {"type": "string"},
                "bluesky":      {"type": "string"},
                "linkedin":     {"type": "string"},
                "facebook":     {"type": "string"},
                "github":       {"type": "string"},
                "instagram":    {"type": "string"},
                "youtube":      {"type": "string"},
                "website":      {"type": "string"},
                "orcid":        {"type": "string"}
              }
            }
          }
        },
        "required": ["name"]
      }
    }
  },
  "required": [
    "name",
    "title",
    "description",
    "repo_url",
    "bug_reports_url",
    "pypi_url",
    "last_updated",
    "maintainers"
  ]
}
