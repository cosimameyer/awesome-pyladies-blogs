{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "name":    { "type": "string" },
    "city":    { "type": "string" },
    "country": { "type": "string" },
    "email":   { "type": "string" },
    "website": { "type": "string" },
    "social_media": {
      "type": "object",
      "properties": {
        "twitter":   { "type": "string" },
        "facebook":  { "type": "string" },
        "github":    { "type": "string" },
        "linkedin":  { "type": "string" },
        "instagram": { "type": "string" },
        "meetup":    { "type": "string" },
        "mastodon":  { "type": "string" },
        "bluesky":   { "type": "string" },
        "youtube":   { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "required": ["name", "city", "country"],
  "additionalProperties": false
}
